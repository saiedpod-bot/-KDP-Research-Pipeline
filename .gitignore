# ============================================================================
# KDP Discovery Engine Pro — .gitignore
# ============================================================================

# --- Secrets & Configuration (NEVER commit these) --------------------------
.env
config.ini
credentials.json
*.pem

# --- Python cache -----------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
*.egg
.eggs/

# --- Virtual environment ----------------------------------------------------
venv/
.venv/
env/
.env/

# --- IDE / Editor -----------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Runtime data -----------------------------------------------------------
data/*.db
data/*.db-journal
data/*.db-wal
data/*.log
output/

# --- Logs -------------------------------------------------------------------
*.log

# --- Build artifacts --------------------------------------------------------
dist/
dist_obfuscated/
build/
*.spec
*.manifest

# --- Obfuscation artifacts --------------------------------------------------
pyarmor/

# --- OS files ---------------------------------------------------------------
Thumbs.db
.DS_Store
desktop.ini
