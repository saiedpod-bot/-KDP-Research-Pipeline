# SerpApi key — get yours at https://serpapi.com (free tier: 100 searches/month)
SERPAPI_KEY=your_serpapi_key_here

# Google Sheet ID (optional) — paste the ID from your Google Sheet URL
# SHEET_ID=1abc123def456...

# Path to Google service account credentials JSON (optional)
# GOOGLE_APPLICATION_CREDENTIALS=credentials.json

# Google Cloud API key — for Imagen image generation (Design Studio)
# Get from: https://console.cloud.google.com/apis/credentials
# GOOGLE_CLOUD_API_KEY=

# Google Cloud project ID — for Imagen image generation
# GOOGLE_CLOUD_PROJECT=
